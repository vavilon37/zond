# === Telegram бот ===
# Токен от @BotFather
BOT_TOKEN=

# Через запятую: твой Telegram user id (узнать у @userinfobot)
ADMIN_IDS=123456789

# === 3X-UI панель ===
# URL панели (если бот на том же сервере что и 3X-UI — http://127.0.0.1:2053)
XUI_URL=https://zondvpn.duckdns.org:8000
# Базовый путь панели (с обоих сторон / )
XUI_BASE_PATH=/6bbcf657e39ef3a6/
# API token из `x-ui setting -getApiToken` на сервере
XUI_API_TOKEN=
# Внутренний id inbound который выдаём юзерам (Reality, id=1)
XUI_INBOUND_ID=1
# Базовый домен subscription endpoint (включая порт, БЕЗ конечного /)
XUI_SUB_BASE_URL=https://zondvpn.duckdns.org:2097
# Subscription path в 3X-UI (обычно /<rand>/, тот что в Settings → Subscription)
XUI_SUB_PATH=/d89194496239d36a/

# === CryptoBot (@CryptoBot → My Apps → Create App) ===
CRYPTOBOT_TOKEN=

# === СБП реквизиты (показываются юзерам) ===
SBP_PHONE=+79991234567
SBP_BANK=Тинькофф
SBP_NAME=Иван И.

# === Прочее ===
DB_PATH=data.sqlite3
